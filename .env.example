# Copy this file to .env and replace the placeholder values.

BQE_CORE_CLIENT_ID="<your-client-id>"
BQE_CORE_CLIENT_SECRET="<your-client-secret>"
BQE_CORE_REDIRECT_URI="http://localhost:8400/callback"
BQE_CORE_SCOPE="read:core offline_access"

# Optional: only set this if your tenant requires a specific API base URL.
# BQE_CORE_API_BASE_URL="https://api.bqecore.com/api"
